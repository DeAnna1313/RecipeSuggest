---
import Base from '../layouts/Base.astro';
import {
  Show,
  SignInButton,
  SignOutButton,
  SignUpButton,
  UserButton,
} from '@clerk/astro/components';
---

<Base>
  <div
    class="container"
    data-testid="recipe-app"
    x-data="recipeApp"
    @open-recipe="openModal($event.detail)"
    @keydown.escape.window="handleEscape()"
  >

    <!-- ─── Header ─────────────────────────────── -->
    <header class="site-header no-print">
      <div class="site-header__nav">
        <a href="/" class="site-header__logo">
          <span class="site-header__logo-icon">🍳</span>
          RecipeSuggest
        </a>
        <nav class="site-nav">
          <a href="/" class="site-nav__link site-nav__link--active">Suggest</a>
          <a href="/bookmarks" class="site-nav__link">Bookmarks</a>
        </nav>
        <button
          type="button"
          class="theme-toggle no-print"
          onclick="window.toggleRecipeSuggestTheme?.()"
          title="Toggle light or dark theme"
        >
          <span class="theme-toggle__icon" aria-hidden="true">◐</span>
          <span class="theme-toggle__label">Theme</span>
        </button>
        <div class="auth-actions">
          <Show when="signed-out">
            <SignInButton mode="modal" asChild>
              <button type="button" class="auth-link">Sign in</button>
            </SignInButton>
            <SignUpButton mode="modal" asChild>
              <button type="button" class="auth-link auth-link--primary">Sign up</button>
            </SignUpButton>
            <SignInButton mode="modal" asChild>
              <button type="button" class="auth-link auth-link--subtle">Forgot password?</button>
            </SignInButton>
          </Show>
          <Show when="signed-in">
            <a href="/bookmarks" class="auth-link">My bookmarks</a>
            <UserButton />
            <SignOutButton asChild>
              <button type="button" class="auth-link auth-link--subtle">Sign out</button>
            </SignOutButton>
          </Show>
        </div>
      </div>
      <p class="site-header__tagline">Type your ingredients. Get instant recipe ideas.</p>
    </header>

    <!-- ─── Ingredient Input Panel ─────────────── -->
    <section class="ingredient-panel no-print">
      <label class="ingredient-panel__label" for="ingredient-input">
        What's in your kitchen?
      </label>

      <div class="ingredient-input-row">
        <input
          id="ingredient-input"
          class="ingredient-input"
          type="text"
          placeholder="e.g. chicken, garlic, lemon…"
          x-model="currentInput"
          @keydown.enter.prevent="addIngredient()"
          @keydown.comma.prevent="addIngredient()"
          autocomplete="off"
        />
        <button class="btn btn--add" type="button" @click="addIngredient()">
          + Add
        </button>
      </div>

      <!-- Tag list -->
      <div class="tag-list" x-show="ingredients.length > 0">
        <template x-for="(item, idx) in ingredients" :key="idx">
          <span class="tag">
            <span x-text="item"></span>
            <button class="tag__remove" @click="removeIngredient(idx)" aria-label="Remove ingredient">×</button>
          </span>
        </template>
      </div>

      <div class="constraint-panel" x-show="ingredients.length > 0">
        <p class="constraint-panel__title">Preferences (optional)</p>
        <div class="constraint-grid">
          <label class="constraint-check">
            <input type="checkbox" x-model="cVegan" @change="cVegan && (cVegetarian = true)" />
            Vegan
          </label>
          <label class="constraint-check">
            <input type="checkbox" x-model="cVegetarian" :disabled="cVegan" />
            Vegetarian
          </label>
          <label class="constraint-check">
            <input type="checkbox" x-model="cGlutenFree" />
            Gluten-free
          </label>
          <label class="constraint-check">
            <input type="checkbox" x-model="cDairyFree" />
            Dairy-free
          </label>
          <label class="constraint-check">
            <input type="checkbox" x-model="cNutFree" />
            Nut-free
          </label>
        </div>
        <label class="constraint-mins">
          Max time (minutes)
          <input
            type="number"
            class="constraint-mins__input"
            x-model="cMaxMins"
            min="5"
            max="300"
            placeholder="e.g. 45"
          />
        </label>
        <label class="constraint-mins">
          Servings (for amounts)
          <input
            type="number"
            class="constraint-mins__input"
            x-model="cServings"
            min="1"
            max="24"
            placeholder="4"
          />
        </label>
        <label class="constraint-notes">
          Units
          <select class="constraint-mins__input" x-model="cUnitSystem">
            <option value="">Default (mixed)</option>
            <option value="us">US (cups, tbsp, oz…)</option>
            <option value="metric">Metric (g, ml, L…)</option>
          </select>
        </label>
        <div class="constraint-notes">
          <span class="constraint-panel__title">Cooking hardware</span>
          <div class="constraint-grid constraint-grid--appliances">
            <label class="constraint-check">
              <input type="checkbox" x-model="cApplianceMicrowave" @change="onApplianceToggle('microwave')" />
              Microwave
            </label>
            <label class="constraint-check">
              <input type="checkbox" x-model="cApplianceStove" @change="onApplianceToggle('stove')" />
              Stove
            </label>
            <label class="constraint-check">
              <input type="checkbox" x-model="cApplianceOven" @change="onApplianceToggle('oven')" />
              Oven
            </label>
            <label class="constraint-check">
              <input type="checkbox" x-model="cApplianceAirFryer" @change="onApplianceToggle('airFryer')" />
              Air fryer
            </label>
            <label class="constraint-check">
              <input type="checkbox" x-model="cApplianceNone" @change="onApplianceToggle('none')" />
              None
            </label>
            <label class="constraint-check">
              <input type="checkbox" x-model="cApplianceOther" @change="onApplianceToggle('other')" />
              Other
            </label>
          </div>
          <input
            x-show="cApplianceOther"
            type="text"
            class="constraint-notes__input"
            x-model="cApplianceOtherText"
            placeholder="e.g. rice cooker, grill, hot plate"
          />
        </div>
        <label class="constraint-notes">
          Extra notes
          <textarea
            class="constraint-notes__input"
            x-model="cNotes"
            rows="2"
            placeholder="e.g. no cilantro, mild spice only…"
          />
        </label>
      </div>

      <!-- Actions -->
      <div class="ingredient-panel__actions">
        <span class="ingredient-panel__count" x-show="ingredients.length > 0">
          <span x-text="ingredients.length"></span> ingredient<span x-show="ingredients.length !== 1">s</span>
        </span>

        <form
          id="suggest-form"
          hx-post="/api/suggest"
          hx-target="#recipe-results"
          hx-swap="innerHTML"
          hx-indicator="#recipe-results"
          @htmx:before-request="onBeforeRequest($event)"
        >
          <input type="hidden" name="ingredients" :value="ingredients.join(',')" />
          <input type="hidden" name="constraints" :value="constraintsPayload()" />
          <button
            class="btn btn--primary"
            type="submit"
            :disabled="ingredients.length === 0 || loading"
            :aria-busy="loading"
            :aria-label="loading ? 'Searching for recipes, please wait' : 'Suggest recipes from your ingredients'"
            x-text="loading ? 'Finding recipes…' : '✨ Suggest Recipes'"
          ></button>
        </form>
      </div>

      <div class="recent-searches" x-show="history.length > 0">
        <div class="recent-searches__header">
          <p class="recent-searches__title">Recent searches</p>
          <button
            class="recent-searches__clear"
            type="button"
            @click="clearHistory()"
          >
            Clear history
          </button>
        </div>

        <div class="recent-searches__list">
          <template x-for="entry in history" :key="entry.key">
            <button
              class="recent-searches__item"
              type="button"
              @click="runHistorySearch(entry)"
              :disabled="loading"
            >
              <span x-text="entry.ingredients.join(', ')"></span>
            </button>
          </template>
        </div>
      </div>
    </section>

    <!-- ─── Bookmarks Section ──────────────────── -->
    <section
      class="bookmarks-section no-print"
      x-data="{ showBookmarks: false }"
      x-show="$store.bookmarks.list.length > 0"
    >
      <button
        class="bookmarks-toggle"
        @click="showBookmarks = !showBookmarks"
      >
        <span x-text="showBookmarks ? '▾' : '▸'"></span>
        Bookmarked Recipes
        <span class="bookmarks-toggle__count" x-text="$store.bookmarks.list.length"></span>
      </button>

      <a href="/bookmarks" class="bookmarks-section__link">Open bookmarks page</a>

      <div class="recipe-grid" x-show="showBookmarks" x-transition>
        <template x-for="recipe in $store.bookmarks.list" :key="recipe.id">
          <div
            class="recipe-card"
            role="button"
            tabindex="0"
            @click="$dispatch('open-recipe', recipe)"
            @keydown.enter="$dispatch('open-recipe', recipe)"
          >
            <div class="recipe-card__header">
              <h3 class="recipe-card__title" x-text="recipe.title"></h3>
              <button
                class="recipe-card__bookmark is-bookmarked"
                @click.stop="$store.bookmarks.toggle(recipe)"
                title="Remove bookmark"
                aria-label="Remove bookmark"
              >★</button>
            </div>
            <p class="recipe-card__desc" x-text="recipe.description"></p>
            <div class="recipe-card__meta">
              <span class="recipe-card__time" x-text="'⏱ ' + recipe.cookTime"></span>
              <span
                class="badge"
                :class="{
                  'badge--easy': recipe.difficulty === 'easy',
                  'badge--medium': recipe.difficulty === 'medium',
                  'badge--hard': recipe.difficulty === 'hard'
                }"
                x-text="recipe.difficulty"
              ></span>
            </div>
          </div>
        </template>
      </div>
    </section>

    <!-- ─── Results Area ───────────────────────── -->
    <section class="recipes-section no-print">
      <div id="recipe-results">
        <div class="empty-state">
          <div class="empty-state__icon">🥘</div>
          <p class="empty-state__text">Add your ingredients above and hit <strong>Suggest Recipes</strong> to get started.</p>
        </div>
      </div>
    </section>

    <!-- ─── Recipe Detail Modal ────────────────── -->
    <div
      class="modal-backdrop"
      x-show="modalOpen"
      x-transition:enter="fadeIn"
      @click.self="modalOpen = false"
      style="display: none;"
    >
      <div class="modal" @click.stop>
        <button class="modal__close no-print" @click="modalOpen = false" aria-label="Close modal">×</button>

        <h2 class="modal__title" x-text="activeRecipe.title"></h2>
        <p class="modal__desc" x-text="activeRecipe.description"></p>

        <div class="modal__meta">
          <div class="modal__meta-item">
            <span>⏱</span>
            <span x-text="activeRecipe.cookTime"></span>
          </div>
          <div class="modal__meta-item">
            <span
              class="badge"
              :class="{
                'badge--easy': activeRecipe.difficulty === 'easy',
                'badge--medium': activeRecipe.difficulty === 'medium',
                'badge--hard': activeRecipe.difficulty === 'hard'
              }"
              x-text="activeRecipe.difficulty"
            ></span>
          </div>
        </div>

        <div class="modal__media no-print" x-show="activeRecipe.imageUrl || previewImageLoading">
          <img :src="activeRecipe.imageUrl" :alt="activeRecipe.title" class="modal__photo" />
          <div class="recipe-card__placeholder recipe-card__placeholder--loading" x-show="previewImageLoading && !activeRecipe.imageUrl">
            Generating finished dish photo...
          </div>
        </div>

        <div class="modal__servings-row no-print">
          <label class="modal__servings">
            Servings
            <input
              type="number"
              class="modal__servings-input"
              min="1"
              max="48"
              x-model.number="modalTargetServings"
            />
          </label>
          <p class="modal__servings-hint" x-show="recipeBaseServings() !== modalTargetServings">
            Amounts scaled from
            <span x-text="recipeBaseServings()"></span>
            to
            <span x-text="modalTargetServings"></span>
          </p>
        </div>

        <h3 class="modal__section-title">Ingredients</h3>
        <div class="modal__ingredients">
          <template x-for="ing in scaledIngredientLines()" :key="ing">
            <span class="modal__ingredient" x-text="ing"></span>
          </template>
        </div>

        <h3 class="modal__section-title">Instructions</h3>
        <ol class="modal__steps">
          <template x-for="step in activeRecipe.instructions" :key="step">
            <li class="modal__step">
              <span class="modal__step-text" x-text="step"></span>
            </li>
          </template>
        </ol>

        <p class="modal__copy-status no-print" x-show="copyStatus" x-text="copyStatus"></p>

        <div class="modal__toolbar no-print">
          <div class="modal__menu" @click.outside="modalMenuOpen = false">
            <button
              type="button"
              class="btn btn--ghost"
              @click="modalMenuOpen = !modalMenuOpen"
              :aria-expanded="modalMenuOpen"
            >
              Actions
            </button>
            <div class="modal__menu-list" x-show="modalMenuOpen" x-transition style="display: none;">
              <button type="button" class="modal__menu-item" @click="runModalAction('print')">Print</button>
              <button type="button" class="modal__menu-item" @click="runModalAction('download')">Download HTML</button>
              <button type="button" class="modal__menu-item" @click="runModalAction('ingredients')">Copy ingredients</button>
              <button type="button" class="modal__menu-item" @click="runModalAction('shop')">Copy shop hints</button>
              <button type="button" class="modal__menu-item" @click="runModalAction('mergedShop')">Merged shop (bookmarks)</button>
              <button
                type="button"
                class="modal__menu-item"
                x-show="!activeRecipe.imageUrl"
                :disabled="previewImageLoading"
                @click="runModalAction('photo')"
              >
                <span x-show="!previewImageLoading">AI dish photo</span>
                <span x-show="previewImageLoading">Loading…</span>
              </button>
              <button type="button" class="modal__menu-item" @click="runModalAction('cook')">Cook mode</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="cook-mode no-print"
      x-show="cookModeOpen"
      x-transition:enter="fadeIn"
      style="display: none;"
      role="dialog"
      aria-modal="true"
      :aria-label="'Cook mode: ' + (activeRecipe.title || 'recipe')"
    >
      <div class="cook-mode__inner">
        <header class="cook-mode__header">
          <button type="button" class="cook-mode__close" @click="closeCookMode()" aria-label="Exit cook mode">×</button>
          <p class="cook-mode__title" x-text="activeRecipe.title"></p>
          <p class="cook-mode__progress">
            Step <span x-text="cookStepIndex + 1"></span>
            of
            <span x-text="(activeRecipe.instructions && activeRecipe.instructions.length) ? activeRecipe.instructions.length : 1"></span>
          </p>
        </header>
        <div class="cook-mode__body">
          <p class="cook-mode__step" x-show="activeRecipe.instructions && activeRecipe.instructions.length" x-text="activeRecipe.instructions[cookStepIndex]"></p>
          <p class="cook-mode__empty" x-show="!activeRecipe.instructions || activeRecipe.instructions.length === 0">No steps for this recipe.</p>
        </div>

        <div class="cook-mode__timer no-print">
          <label class="cook-timer__label">
            Timer (minutes)
            <input type="number" class="cook-timer__input" x-model="cookTimerMins" min="1" max="120" />
          </label>
          <button type="button" class="btn btn--ghost" @click="startCookTimer()" :disabled="cookTimerRemaining !== null">Start</button>
          <button type="button" class="btn btn--ghost" @click="stopCookTimer()" x-show="cookTimerRemaining !== null">Stop</button>
          <span class="cook-timer__display" x-show="cookTimerRemaining !== null" x-text="formatCookCountdown(cookTimerRemaining)"></span>
          <p class="cook-timer__done" x-show="cookTimerDone">Time is up!</p>
        </div>

        <footer class="cook-mode__footer">
          <button type="button" class="btn btn--ghost" @click="prevCookStep()" :disabled="cookStepIndex === 0">Previous</button>
          <button
            type="button"
            class="btn btn--primary"
            x-show="activeRecipe.instructions && activeRecipe.instructions.length > 0 && cookStepIndex < activeRecipe.instructions.length - 1"
            @click="nextCookStep()"
          >Next</button>
          <button
            type="button"
            class="btn btn--primary"
            x-show="activeRecipe.instructions && activeRecipe.instructions.length > 0 && cookStepIndex >= activeRecipe.instructions.length - 1"
            @click="closeCookMode()"
          >Done</button>
        </footer>
      </div>
    </div>

  </div>

  <!-- ─── Alpine.js App Logic ────────────────── -->
  <script>
    window.recipeImageCacheKey = 'recipesuggest_recipe_images';
    window.recipeImageInflight = new Map();
    window.encodeRecipeData = function (recipe) {
      return btoa(unescape(encodeURIComponent(JSON.stringify(recipe))));
    };
    window.readRecipeImageCache = function () {
      try {
        return JSON.parse(localStorage.getItem(window.recipeImageCacheKey) || '{}');
      } catch (_e) {
        return {};
      }
    };
    window.writeRecipeImageCache = function (cache) {
      localStorage.setItem(window.recipeImageCacheKey, JSON.stringify(cache));
    };
    window.applyRecipeImageToCard = function (card, recipe, imageUrl) {
      if (!card || !recipe || !imageUrl) return;
      const nextRecipe = { ...recipe, imageUrl };
      card.dataset.recipe = window.encodeRecipeData(nextRecipe);
      const bookmarkBtn = card.querySelector('.recipe-card__bookmark');
      if (bookmarkBtn) {
        bookmarkBtn.dataset.recipe = window.encodeRecipeData(nextRecipe);
      }
      const img = card.querySelector('.recipe-card__image');
      const placeholder = card.querySelector('.recipe-card__placeholder');
      if (img) img.src = imageUrl;
      if (placeholder) {
        placeholder.textContent = 'Finished dish photo';
        placeholder.classList.remove('recipe-card__placeholder--loading');
      }
      card.classList.add('recipe-card--has-image');
      document.dispatchEvent(
        new CustomEvent('recipe-image-ready', {
          detail: { id: nextRecipe.id, imageUrl },
        }),
      );
    };
    window.ensureRecipeImage = async function (recipe) {
      if (!recipe || !recipe.id) throw new Error('Missing recipe for image');
      if (recipe.imageUrl) return recipe.imageUrl;
      const cache = window.readRecipeImageCache();
      if (cache[recipe.id]) return cache[recipe.id];
      if (window.recipeImageInflight.has(recipe.id)) {
        return window.recipeImageInflight.get(recipe.id);
      }
      const request = fetch('/api/bookmark-image', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(recipe),
      })
        .then(async (res) => {
          let data = {};
          try {
            data = await res.json();
          } catch {
            if (!res.ok) throw new Error('Network error loading photo');
          }
          if (!res.ok) {
            throw new Error(
              typeof data.error === 'string' ? data.error : 'Image request failed',
            );
          }
          const nextCache = window.readRecipeImageCache();
          nextCache[recipe.id] = data.imageUrl;
          window.writeRecipeImageCache(nextCache);
          return data.imageUrl;
        })
        .finally(() => {
          window.recipeImageInflight.delete(recipe.id);
        });
      window.recipeImageInflight.set(recipe.id, request);
      return request;
    };

    window.dispatchOpenRecipe = function (el) {
      const raw = el && el.dataset ? el.dataset.recipe : null;
      if (!raw) return;
      const detail = JSON.parse(decodeURIComponent(escape(atob(raw))));
      const app = document.querySelector('[data-testid="recipe-app"]');
      const target = app || document.documentElement;
      target.dispatchEvent(
        new CustomEvent('open-recipe', { detail, bubbles: true }),
      );
    };

    // ── Global bookmark handler (used by HTMX-rendered cards) ────────
    window.handleBookmark = function(btn) {
      const recipe = JSON.parse(decodeURIComponent(escape(atob(btn.dataset.recipe))));
      const key = 'recipesuggest_bookmarks';
      let bookmarks = JSON.parse(localStorage.getItem(key) || '[]');
      const exists = bookmarks.some(r => r.id === recipe.id);

      if (exists) {
        bookmarks = bookmarks.filter(r => r.id !== recipe.id);
        btn.classList.remove('is-bookmarked');
        btn.querySelector('span').textContent = '☆';
      } else {
        bookmarks.push(recipe);
        btn.classList.add('is-bookmarked');
        btn.querySelector('span').textContent = '★';
      }
      localStorage.setItem(key, JSON.stringify(bookmarks));

      // Sync Alpine bookmark store if available
      if (window.Alpine) {
        Alpine.store('bookmarks').list = bookmarks;
      }
      if (typeof window.queueBookmarkSync === "function") {
        window.queueBookmarkSync();
      }
    };

    // Re-initialize bookmark buttons after HTMX swaps in new content
    document.body.addEventListener('htmx:afterSwap', () => {
      const key = 'recipesuggest_bookmarks';
      const bookmarks = JSON.parse(localStorage.getItem(key) || '[]');
      document.querySelectorAll('.recipe-card__bookmark[data-recipe-id]').forEach(btn => {
        const id = btn.dataset.recipeId;
        const isBookmarked = bookmarks.some(r => r.id === id);
        if (isBookmarked) {
          btn.classList.add('is-bookmarked');
          btn.querySelector('span').textContent = '★';
        }
      });
    });

    const initBookmarksStore = () => {
      // Bookmark store persisted in localStorage
      window.Alpine.store('bookmarks', {
        list: JSON.parse(localStorage.getItem('recipesuggest_bookmarks') || '[]'),

        has(id) {
          return this.list.some(r => r.id === id);
        },

        toggle(recipe) {
          if (this.has(recipe.id)) {
            this.list = this.list.filter(r => r.id !== recipe.id);
          } else {
            this.list = [...this.list, recipe];
          }
          localStorage.setItem('recipesuggest_bookmarks', JSON.stringify(this.list));
          if (typeof window.queueBookmarkSync === "function") {
            window.queueBookmarkSync();
          }
        }
      });
    };

    const initRecipeApp = () => {
      window.Alpine.data('recipeApp', () => ({
        ingredients: [],
        currentInput: '',
        history: [],
        loading: false,
        modalOpen: false,
        modalMenuOpen: false,
        cookModeOpen: false,
        cookStepIndex: 0,
        cVegetarian: false,
        cVegan: false,
        cGlutenFree: false,
        cDairyFree: false,
        cNutFree: false,
        cApplianceMicrowave: false,
        cApplianceStove: false,
        cApplianceOven: false,
        cApplianceAirFryer: false,
        cApplianceNone: false,
        cApplianceOther: false,
        cApplianceOtherText: '',
        cMaxMins: '',
        cServings: '4',
        cUnitSystem: '',
        cNotes: '',
        modalTargetServings: 4,
        copyStatus: '',
        _copyStatusTimer: null,
        previewImageLoading: false,
        cookTimerMins: 5,
        cookTimerRemaining: null,
        cookTimerDone: false,
        _cookTimerId: null,
        activeRecipe: {
          title: '',
          description: '',
          cookTime: '',
          difficulty: 'easy',
          ingredients: [],
          instructions: [],
          servings: 4,
          imageUrl: undefined,
        },

        addIngredient() {
          const val = this.currentInput.trim().replace(/,/g, '');
          if (val && !this.ingredients.includes(val.toLowerCase())) {
            this.ingredients.push(val.toLowerCase());
          }
          this.currentInput = '';
        },

        historyKey(ingredients) {
          return [...ingredients]
            .map(item => item.trim().toLowerCase())
            .sort()
            .join('|');
        },

        saveHistory() {
          if (this.ingredients.length === 0) return;

          const entry = {
            key: this.historyKey(this.ingredients),
            ingredients: [...this.ingredients],
          };

          this.history = [
            entry,
            ...this.history.filter(item => item.key !== entry.key),
          ].slice(0, 20);

          localStorage.setItem('recipesuggest_recent_searches', JSON.stringify(this.history));
        },

        clearHistory() {
          this.history = [];
          localStorage.removeItem('recipesuggest_recent_searches');
        },

        runHistorySearch(entry) {
          if (this.loading) return;

          this.ingredients = [...entry.ingredients];
          this.$nextTick(() => {
            document.getElementById('suggest-form')?.requestSubmit();
          });
        },

        removeIngredient(idx) {
          this.ingredients.splice(idx, 1);
        },

        onApplianceToggle(kind) {
          if (kind === 'none' && this.cApplianceNone) {
            this.cApplianceMicrowave = false;
            this.cApplianceStove = false;
            this.cApplianceOven = false;
            this.cApplianceAirFryer = false;
            this.cApplianceOther = false;
            this.cApplianceOtherText = '';
            return;
          }
          if (kind !== 'none') {
            this.cApplianceNone = false;
          }
          if (kind === 'other' && !this.cApplianceOther) {
            this.cApplianceOtherText = '';
          }
        },

        selectedAppliances() {
          if (this.cApplianceNone) return ['none'];
          const out = [];
          if (this.cApplianceMicrowave) out.push('microwave');
          if (this.cApplianceStove) out.push('stove');
          if (this.cApplianceOven) out.push('oven');
          if (this.cApplianceAirFryer) out.push('air fryer');
          if (this.cApplianceOther) {
            const other = String(this.cApplianceOtherText || '').trim();
            if (other) out.push(other);
          }
          return out;
        },

        onBeforeRequest(evt) {
          this.saveHistory();
          this.loading = true;
          // Show skeleton loading
          const target = document.getElementById('recipe-results');
          if (target) {
            target.innerHTML = `
              <div class="skeleton-grid">
                ${[1,2,3,4].map(() => `
                  <div class="skeleton-card">
                    <div class="skeleton-line skeleton-line--title"></div>
                    <div class="skeleton-line skeleton-line--text"></div>
                    <div class="skeleton-line skeleton-line--text"></div>
                    <div class="skeleton-line skeleton-line--short"></div>
                    <div class="skeleton-line skeleton-line--meta"></div>
                  </div>
                `).join('')}
              </div>
            `;
          }
        },

        openModal(recipe) {
          this.activeRecipe = recipe;
          const base = this.recipeBaseServings();
          this.modalTargetServings = base;
          this.modalOpen = true;
          this.modalMenuOpen = false;
          this.cookModeOpen = false;
          this.cookStepIndex = 0;
          this.copyStatus = '';
          this.stopCookTimer();
          this.cookTimerDone = false;
          if (!this.activeRecipe.imageUrl) {
            this.loadPreviewImage(false);
          }
        },

        pantryTokenSet() {
          const set = new Set();
          for (const p of this.ingredients || []) {
            for (const t of String(p).toLowerCase().split(/[\s,;\/]+/)) {
              if (t.length >= 2) set.add(t);
            }
          }
          return set;
        },

        lineMatchesPantryTokens(line, pantryTokens) {
          const words = String(line)
            .toLowerCase()
            .split(/[\s,;\/]+/)
            .filter(Boolean);
          for (const w of words) {
            if (pantryTokens.has(w)) return true;
            for (const t of pantryTokens) {
              if (
                w.length >= 2 &&
                t.length >= 2 &&
                (w.includes(t) || t.includes(w))
              )
                return true;
            }
          }
          return false;
        },

        recipeBaseServings() {
          const n = this.activeRecipe.servings;
          const v = parseInt(String(n), 10);
          return Number.isFinite(v) && v > 0 ? v : 4;
        },

        scaleIngredientAmounts(lines, from, to) {
          if (!from || from <= 0 || from === to) return [...lines];
          const factor = to / from;
          return lines.map((line) =>
            String(line).replace(/\b(\d+\.\d+|\d+)\b/g, (match) => {
              const num = parseFloat(match);
              if (!Number.isFinite(num)) return match;
              const x = num * factor;
              const r = Math.round(x * 100) / 100;
              let s = String(r);
              if (s.endsWith(".00")) s = s.slice(0, -3);
              else if (/^\d+\.\d0$/.test(s)) s = s.slice(0, -1);
              return s;
            }),
          );
        },

        scaledIngredientLines() {
          const lines = this.activeRecipe.ingredients || [];
          const from = this.recipeBaseServings();
          let to = Number(this.modalTargetServings);
          if (!Number.isFinite(to) || to < 1) to = from;
          if (to > 48) to = 48;
          return this.scaleIngredientAmounts(lines, from, to);
        },

        showCopyStatus(msg) {
          this.copyStatus = msg;
          if (this._copyStatusTimer) clearTimeout(this._copyStatusTimer);
          this._copyStatusTimer = setTimeout(() => {
            this.copyStatus = '';
          }, 2200);
        },

        async copyIngredientList() {
          const lines = this.scaledIngredientLines();
          if (!lines.length) return;
          try {
            await navigator.clipboard.writeText(lines.join('\n'));
            this.showCopyStatus('Ingredients copied to clipboard');
          } catch {
            this.showCopyStatus('Could not copy');
          }
        },

        linesYouMayNeedToBuy() {
          const pantry = this.pantryTokenSet();
          const rows = this.scaledIngredientLines();
          const out = [];
          for (const line of rows) {
            if (!this.lineMatchesPantryTokens(line, pantry)) out.push(line);
          }
          return out.length ? out : [...rows];
        },

        mergedShopHintsFromBookmarks() {
          const pantry = this.pantryTokenSet();
          const list = window.Alpine.store('bookmarks').list || [];
          const seen = new Set();
          const out = [];
          for (const recipe of list) {
            for (const line of recipe.ingredients || []) {
              if (this.lineMatchesPantryTokens(line, pantry)) continue;
              const key = String(line).trim().toLowerCase();
              if (!key || seen.has(key)) continue;
              seen.add(key);
              out.push(line);
            }
          }
          return out;
        },

        async copyMergedShopList() {
          const lines = this.mergedShopHintsFromBookmarks();
          if (!lines.length) {
            this.showCopyStatus('No merged lines (or all matched pantry)');
            return;
          }
          try {
            await navigator.clipboard.writeText(lines.join('\n'));
            this.showCopyStatus('Merged shop list copied');
          } catch {
            this.showCopyStatus('Could not copy');
          }
        },

        async downloadActiveRecipeHtml() {
          try {
            const res = await fetch('/api/export-recipe-html', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                recipe: {
                  ...this.activeRecipe,
                  ingredients: this.scaledIngredientLines(),
                  servings: Number(this.modalTargetServings) || this.recipeBaseServings(),
                },
              }),
            });
            if (!res.ok) throw new Error('Export failed');
            const blob = await res.blob();
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            const raw = (this.activeRecipe.title || 'recipe').replace(/[^\w\-]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 64);
            a.download = (raw || 'recipe') + '.html';
            a.click();
            URL.revokeObjectURL(url);
            this.showCopyStatus('Recipe downloaded');
          } catch {
            this.showCopyStatus('Download failed');
          }
        },

        async copyShopList() {
          const lines = this.linesYouMayNeedToBuy();
          if (!lines.length) return;
          try {
            await navigator.clipboard.writeText(lines.join('\n'));
            this.showCopyStatus('Shopping hints copied');
          } catch {
            this.showCopyStatus('Could not copy');
          }
        },

        async loadPreviewImage(announce = true) {
          if (this.previewImageLoading || this.activeRecipe.imageUrl) return;
          this.previewImageLoading = true;
          try {
            const imageUrl = await window.ensureRecipeImage(this.activeRecipe);
            this.activeRecipe = {
              ...this.activeRecipe,
              imageUrl,
            };
            if (announce) this.showCopyStatus('Photo added');
          } catch (e) {
            if (announce) {
              this.showCopyStatus(
                e instanceof Error ? e.message : 'Photo failed',
              );
            }
          } finally {
            this.previewImageLoading = false;
          }
        },

        handleEscape() {
          if (this.modalMenuOpen) {
            this.modalMenuOpen = false;
            return;
          }
          if (this.cookModeOpen) {
            this.closeCookMode();
            return;
          }
          this.modalOpen = false;
        },

        runModalAction(action) {
          this.modalMenuOpen = false;
          switch (action) {
            case 'print':
              window.print();
              return;
            case 'download':
              this.downloadActiveRecipeHtml();
              return;
            case 'ingredients':
              this.copyIngredientList();
              return;
            case 'shop':
              this.copyShopList();
              return;
            case 'mergedShop':
              this.copyMergedShopList();
              return;
            case 'photo':
              this.loadPreviewImage();
              return;
            case 'cook':
              this.openCookMode();
              return;
          }
        },

        formatCookCountdown(sec) {
          if (sec == null || sec < 0) return '';
          const m = Math.floor(sec / 60);
          const s = sec % 60;
          return m + ':' + String(s).padStart(2, '0');
        },

        startCookTimer() {
          this.stopCookTimer();
          this.cookTimerDone = false;
          let mins = parseInt(String(this.cookTimerMins), 10);
          if (!Number.isFinite(mins) || mins < 1) mins = 5;
          if (mins > 120) mins = 120;
          this.cookTimerRemaining = mins * 60;
          this._cookTimerId = setInterval(() => {
            this.cookTimerRemaining--;
            if (this.cookTimerRemaining <= 0) {
              this.stopCookTimer(true);
            }
          }, 1000);
        },

        stopCookTimer(ding) {
          if (this._cookTimerId) {
            clearInterval(this._cookTimerId);
            this._cookTimerId = null;
          }
          this.cookTimerRemaining = null;
          if (ding) {
            this.cookTimerDone = true;
            try {
              const AC = window.AudioContext || window.webkitAudioContext;
              if (AC) {
                const ctx = new AC();
                const o = ctx.createOscillator();
                const g = ctx.createGain();
                o.connect(g);
                g.connect(ctx.destination);
                o.frequency.value = 880;
                g.gain.value = 0.07;
                o.start();
                setTimeout(() => {
                  o.stop();
                  ctx.close();
                }, 220);
              }
            } catch (_e) {}
          }
        },

        closeCookMode() {
          this.stopCookTimer();
          this.cookModeOpen = false;
        },

        openCookMode() {
          this.stopCookTimer();
          this.cookTimerDone = false;
          this.cookStepIndex = 0;
          this.cookModeOpen = true;
        },

        nextCookStep() {
          const n = this.activeRecipe.instructions?.length ?? 0;
          if (this.cookStepIndex < n - 1) this.cookStepIndex++;
        },

        prevCookStep() {
          if (this.cookStepIndex > 0) this.cookStepIndex--;
        },

        constraintsPayload() {
          const max = parseInt(String(this.cMaxMins), 10);
          const serv = parseInt(String(this.cServings), 10);
          const unit = String(this.cUnitSystem || '').trim();
          return JSON.stringify({
            vegetarian: !!this.cVegetarian || !!this.cVegan,
            vegan: !!this.cVegan,
            glutenFree: !!this.cGlutenFree,
            dairyFree: !!this.cDairyFree,
            nutFree: !!this.cNutFree,
            appliances: this.selectedAppliances(),
            maxTimeMins:
              Number.isFinite(max) && max > 0 ? max : undefined,
            servings:
              Number.isFinite(serv) && serv >= 1 && serv <= 24 ? serv : undefined,
            unitSystem:
              unit === 'us' || unit === 'metric' ? unit : undefined,
            notes: String(this.cNotes || '').trim() || undefined,
          });
        },

        suggestRetryMarkup() {
          return `<div class="error-message"><p>Something went wrong reaching the server. Check your connection and try again.</p><button type="button" class="btn btn--primary" id="suggest-retry">Try again</button></div>`;
        },

        bindSuggestRetryOnce() {
          document.getElementById('suggest-retry')?.addEventListener(
            'click',
            () => document.getElementById('suggest-form')?.requestSubmit(),
            { once: true },
          );
        },

        init() {
          this.history = JSON.parse(localStorage.getItem('recipesuggest_recent_searches') || '[]');

          document.addEventListener('recipe-image-ready', (evt) => {
            const detail = evt.detail || {};
            if (detail.id && this.activeRecipe.id === detail.id && detail.imageUrl) {
              this.activeRecipe = {
                ...this.activeRecipe,
                imageUrl: detail.imageUrl,
              };
            }
          });

          document.body.addEventListener('htmx:afterRequest', (evt) => {
            this.loading = false;
            const xhr = evt.detail.xhr;
            if (!xhr || !xhr.responseURL || xhr.responseURL.indexOf('/api/suggest') === -1) {
              return;
            }
            if (!evt.detail.successful && xhr.status !== 429) {
              const target = document.getElementById('recipe-results');
              if (target) {
                target.innerHTML = this.suggestRetryMarkup();
                this.bindSuggestRetryOnce();
              }
            }
          });

          document.body.addEventListener('htmx:sendError', () => {
            this.loading = false;
            const target = document.getElementById('recipe-results');
            if (target) {
              target.innerHTML = this.suggestRetryMarkup();
              this.bindSuggestRetryOnce();
            }
          });
        }
      }));
    };

    let alpineBooted = false;
    const bootAlpineModules = () => {
      if (alpineBooted || !window.Alpine) return;
      alpineBooted = true;
      initBookmarksStore();
      initRecipeApp();
      const app = document.querySelector('[data-testid="recipe-app"]');
      if (app) window.Alpine.initTree(app);
    };

    const waitForAlpine = () => {
      if (window.Alpine) {
        bootAlpineModules();
        return;
      }
      window.setTimeout(waitForAlpine, 25);
    };

    document.addEventListener('alpine:init', bootAlpineModules, { once: true });
    waitForAlpine();
  </script>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      document.body.addEventListener("htmx:beforeSwap", function (evt) {
        var xhr = evt.detail.xhr;
        if (
          xhr &&
          xhr.status >= 400 &&
          xhr.responseURL &&
          xhr.responseURL.indexOf("/api/suggest") !== -1
        ) {
          evt.detail.shouldSwap = true;
        }
      });
    });
  </script>
</Base>
