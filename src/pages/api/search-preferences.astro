---
export const prerender = false;

import { getStore } from "@netlify/blobs";
import {
  normalizeSearchPreferences,
  type SearchPreferencesState,
} from "../../lib/search-preferences";

function json(data: unknown, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: { "Content-Type": "application/json" },
  });
}

const auth = await Astro.locals.auth();
const userId = auth.userId;

if (!userId) {
  return json({ error: "Unauthorized" }, 401);
}

let store: ReturnType<typeof getStore>;
try {
  store = getStore("recipe-search-preferences");
} catch {
  return json({ error: "Search preferences storage is not configured." }, 503);
}

const blobKey = `user-${userId}`;

if (Astro.request.method === "GET") {
  try {
    const data = await store.get(blobKey, { type: "json" });
    const preferences = normalizeSearchPreferences(
      data ?? {},
    ) as Partial<SearchPreferencesState>;
    return json({ preferences });
  } catch {
    return json({ preferences: {} });
  }
}

if (Astro.request.method === "PUT") {
  try {
    const body = (await Astro.request.json()) as { preferences?: unknown };
    const preferences = normalizeSearchPreferences(body?.preferences);
    await store.setJSON(blobKey, preferences);
    return json({ ok: true });
  } catch (e: unknown) {
    const msg = e instanceof Error ? e.message : "Save failed";
    return json({ error: msg }, 500);
  }
}

return new Response("Method not allowed", { status: 405 });
---
