---
import Base from "../layouts/Base.astro";
import { SignUp } from "@clerk/astro/components";
---

<Base title="Sign Up — RecipeSuggest">
  <div class="container">
    <header class="site-header">
      <div class="site-header__nav">
        <a href="/" class="site-header__logo">
          <span class="site-header__logo-icon">🍳</span>
          RecipeSuggest
        </a>
        <nav class="site-nav">
          <a href="/" class="site-nav__link">Suggest</a>
          <a href="/bookmarks" class="site-nav__link">Bookmarks</a>
          <a href="/sign-in" class="site-nav__link">Sign in</a>
        </nav>
      </div>
      <p class="site-header__tagline">Create your account to keep your recipe workflow connected.</p>
    </header>

    <section class="auth-page">
      <div class="auth-page__intro">
        <p class="auth-page__eyebrow">New account</p>
        <h1 class="auth-page__title">Create your account</h1>
        <p class="auth-page__copy">
          Once email and password sign-in is enabled in Clerk, password resets will be handled from the sign-in page.
        </p>
      </div>

      <div class="auth-page__card">
        <SignUp signInUrl="/sign-in" />
      </div>
    </section>
  </div>
</Base>
